# ── Step 1: Razorpay ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Step 2: Twilio SMS ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── Step 2: Gmail SMTP ────────────────────────────────────────────────────────
# Enable 2FA on Gmail → App Passwords → generate one
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Step 3: App URL (your domain) ─────────────────────────────────────────────
APP_BASE_URL=https://foodhubpro.in

# ── Step 4: Database (Railway/RDS) ────────────────────────────────────────────
DB_URL=jdbc:mysql://your-host:3306/foodhub_db?useSSL=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_password

# ── Step 5: AWS S3 ────────────────────────────────────────────────────────────
AWS_S3_BUCKET=foodhub-images
AWS_REGION=ap-south-1
AWS_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── JWT (change this to a random 64-char string) ──────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_key_min_64_chars_xxxx

# ── Port ──────────────────────────────────────────────────────────────────────
PORT=8082
